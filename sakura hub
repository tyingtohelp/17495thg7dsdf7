local function getOwnerPlayer(model)
	for _, plr in pairs(Players:GetPlayers()) do
		local char = plr.Character
		if not char then continue end
		if char == model then return plr end
		local ancestor = model.Parent
		while ancestor do
			if ancestor == char then return plr end
			ancestor = ancestor.Parent
		end
	end
	return nil
end
local teamCheckCache = {}
local teamCheckCacheTime = {}
local function isTeammate(model)
	local now = os.clock()
	if teamCheckCacheTime[model] and (now - teamCheckCacheTime[model]) < 1 then
		return teamCheckCache[model]
	end
	local function evaluate()
		if permanentTeammateSet[model] then return true end
		local hum = model:FindFirstChildOfClass("Humanoid")
		local rawDn = hum and hum.DisplayName or ""
		local modelName = tostring(model.Name or "")
		local dn = rawDn:gsub("[^a-zA-Z0-9_ ]", "")
		local mn = modelName:gsub("[^a-zA-Z0-9_]", "")
		if permanentTeammateNames[rawDn]
			or (dn ~= "" and permanentTeammateNames[dn])
			or permanentTeammateNames[modelName]
			or (mn ~= "" and permanentTeammateNames[mn]) then
			return true
		end
		if next(permanentTeammateUserIds) then
			for _, plr in pairs(Players:GetPlayers()) do
				if permanentTeammateUserIds[plr.UserId] then
					if plr.DisplayName == rawDn or plr.Name == rawDn
						or plr.DisplayName == dn  or plr.Name == dn
						or plr.Name == modelName  or plr.Name == mn then
						return true
					end
				end
			end
		end
		local owner = getOwnerPlayer(model)
		if owner then
			if owner == LocalPlayer then return true end
			if permanentTeammateUserIds[owner.UserId] then return true end
			if LocalPlayer.Team ~= nil and owner.Team == LocalPlayer.Team then return true end
			return false
		end
		return false
	end
	local res = evaluate()
	teamCheckCache[model] = res
	teamCheckCacheTime[model] = now
	return res
end
