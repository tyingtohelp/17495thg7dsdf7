local function applyNoRecoil()
	local weaponConfigs = game:GetService("ReplicatedStorage"):FindFirstChild("Shared")
	if not weaponConfigs then return end
	weaponConfigs = weaponConfigs:FindFirstChild("Configs")
	if not weaponConfigs then return end
	weaponConfigs = weaponConfigs:FindFirstChild("Weapon")
	if not weaponConfigs then return end
	for _, wep in ipairs(weaponConfigs:GetDescendants()) do
		if wep:IsA("ModuleScript") then
			task.spawn(function()
				pcall(function()
					local data = require(wep)
					if type(data) == "table" then
						local function zeroOut(t)
							for k, v in pairs(t) do
								if type(v) == "number" then t[k] = 0 end
								if type(v) == "table" then zeroOut(v) end
							end
						end
						if data.Recoil then zeroOut(data.Recoil) end
						if data.Spread then zeroOut(data.Spread) end
						if data.CameraKick then zeroOut(data.CameraKick) end
						if data.RecoilData then zeroOut(data.RecoilData) end
						if data.ViewKick then zeroOut(data.ViewKick) end
					end
				end)
			end)
		end
	end
end
