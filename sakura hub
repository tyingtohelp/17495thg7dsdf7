local STUD_PER_METER  = 3.57   
local MATCH_TOLERANCE = 40      
local function getTagTeammates()
	local pg = LocalPlayer:FindFirstChildOfClass("PlayerGui")
	local tagUI = pg and pg:FindFirstChild("TagInterface")
	if not tagUI then return nil end
	local rootFrame = tagUI:FindFirstChildOfClass("Frame")
	if not rootFrame then return nil end
	local entries = {}
	for _, child in ipairs(rootFrame:GetChildren()) do
		if not child:IsA("Frame") then continue end
		if child.Name == "Objective" or child.Name == "Explosive" then continue end
		local nameLabel = child:FindFirstChild("2")
		local distLabel = child:FindFirstChild("3")
		if not nameLabel or not distLabel then continue end
		if not nameLabel:IsA("TextLabel") or not distLabel:IsA("TextLabel") then continue end
		local nameText = nameLabel.Text or ""
		local distM    = tonumber((distLabel.Text or ""):match("(%d+)"))
		if not distM then continue end
		table.insert(entries, { name = nameText, distStuds = distM * STUD_PER_METER })
	end
	return #entries > 0 and entries or nil
end
local function matchTagToModels(entries, myPos)
	local alive = {}
	for _, obj in pairs(Workspace:GetChildren()) do
		if not (obj:IsA("Model") and obj.Name == "Male") then continue end
		local root = obj:FindFirstChild("Root")
			or obj:FindFirstChild("HumanoidRootPart")
			or obj.PrimaryPart
		if not root or not root:IsA("BasePart") then continue end
		if obj:FindFirstChildOfClass("BallSocketConstraint", true) then continue end
		table.insert(alive, { model = obj, dist = (root.Position - myPos).Magnitude })
	end
	local result, used = {}, {}
	for _, entry in ipairs(entries) do
		local best, bestDiff = nil, math.huge
		for _, m in ipairs(alive) do
			if used[m.model] then continue end
			local diff = math.abs(m.dist - entry.distStuds)
			if diff < bestDiff then bestDiff = diff; best = m.model end
		end
		if best and bestDiff < MATCH_TOLERANCE then
			result[best] = true
			used[best]   = true
		end
	end
	return result
end
markTeammates = function()
	local myPos = getMyPosition()
	if not myPos then
		MarkTeamCount.Text = "Stand up first!"
		return
	end
	permanentTeammateSet    = {}
	permanentTeammateNames   = {}
	permanentTeammateUserIds = {}
	local entries = getTagTeammates()
	local count   = 0
	if entries then
		local matched = matchTagToModels(entries, myPos)
		for model in pairs(matched) do
			permanentTeammateSet[model] = true
			count += 1
		end
		for _, entry in ipairs(entries) do
			if #entry.name > 0 then
				permanentTeammateNames[entry.name] = true
				for _, plr in pairs(Players:GetPlayers()) do
					if plr ~= LocalPlayer
						and (plr.Name == entry.name or plr.DisplayName == entry.name) then
						permanentTeammateUserIds[plr.UserId] = true
					end
				end
			end
		end
		MarkTeamCount.Text = count == 0
			and "No tag matches (check Debug tab)"
			or (count .. " teammate" .. (count == 1 and "" or "s") .. " detected")
	else
		for _, obj in pairs(Workspace:GetChildren()) do
			if not (obj:IsA("Model") and obj.Name == "Male") then continue end
			local root = obj:FindFirstChild("Root")
				or obj:FindFirstChild("HumanoidRootPart")
				or obj.PrimaryPart
			if not root or not root:IsA("BasePart") then continue end
			if (root.Position - myPos).Magnitude <= MARK_RADIUS then
				permanentTeammateSet[obj] = true
				count += 1
			end
		end
		MarkTeamCount.Text = count == 0
			and "Nobody nearby!"
			or (count .. " teammate" .. (count == 1 and "" or "s") .. " marked (proximity)")
	end
	MarkTeamBtn.BackgroundColor3 = Color3.fromRGB(30, 80, 50)
	task.delay(1, function() MarkTeamBtn.BackgroundColor3 = Color3.fromRGB(50, 110, 70) end)
end
clearTeammates = function()
	permanentTeammateSet    = {}
	permanentTeammateNames   = {}
	permanentTeammateUserIds = {}
	MarkTeamCount.Text = "Cleared"
	task.delay(1.5, function() MarkTeamCount.Text = "No teammates marked" end)
end
