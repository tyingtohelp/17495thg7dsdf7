saveSettings = function()
	local data = {
		espEnabled        = espEnabled,
		espVisCheckEnabled = espVisCheckEnabled,
		espTeamCheck       = espTeamCheck,
		espKeyName         = espKey.Name,
		r = r, g = g, b = b,
		tr = tr, tg = tg, tb = tb,
		aimbotEnabled     = aimbotEnabled,
		aimbotFOV         = aimbotFOV,
		aimbotSmoothing   = aimbotSmoothing,
		aimbotExtraSmooth = aimbotExtraSmooth,
		aimbotPrediction  = aimbotPrediction,
		aimbotPart        = aimbotPart,
		antiRecoilEnabled = antiRecoilEnabled,
		antiRecoilStrength= antiRecoilStrength,
		antiRecoilPresets = antiRecoilPresets,
		humanizeAim      = humanizeAim,
		humanizeStrength = humanizeStrength,
		crosshairEnabled = crosshairEnabled,
		crosshairStyle   = crosshairStyle,
		radarEnabled     = radarEnabled,
		radarRange       = radarRange,
		killFeedEnabled  = killFeedEnabled,
		showDist         = showDist,
		triggerbotEnabled = triggerbotEnabled,
		trigTeamCheck     = trigTeamCheck,
		trigDelay         = trigDelay,
		trigDuration      = trigDuration,
		MARK_RADIUS       = MARK_RADIUS,
		savedKey          = savedKey,
	}
	local ok, err = pcall(function()
		writefile(SETTINGS_FILE, HttpService:JSONEncode(data))
	end)
	if ok then
		setStatus("Saved ?", Color3.fromRGB(80, 220, 130))
	else
		setStatus("Save failed: " .. tostring(err), Color3.fromRGB(220, 80, 80))
	end
end
local function applySettings()
	updateToggle()
	updateVisToggle()
	updateTeamToggle()
	updateAimbotToggle()
	updateRecoilToggle()
	updatePartButtons()
	updateTrigToggle()
	updateTrigTeamToggle()
	KeyBind.Text      = espKey.Name
	KeyBind.TextColor3 = Color3.fromRGB(r, g, b)
	Preview.BackgroundColor3      = Color3.fromRGB(r, g, b)
	EnemyPreview.BackgroundColor3 = Color3.fromRGB(r, g, b)
	TeamPreview.BackgroundColor3  = Color3.fromRGB(tr, tg, tb)
	FOVFill.Size   = UDim2.new(math.clamp(aimbotFOV / 300, 0, 1), 0, 1, 0)
	FOVValue.Text  = tostring(aimbotFOV)
	local speedPct = 1 - aimbotSmoothing
	SmoothFill.Size  = UDim2.new(speedPct, 0, 1, 0)
	SmoothValue.Text = tostring(math.floor(speedPct * 100)) .. "%"
	local xsPct = aimbotExtraSmooth / 0.95
	AimSmoothFill.Size  = UDim2.new(xsPct, 0, 1, 0)
	AimSmoothValue.Text = tostring(math.floor(xsPct * 100)) .. "%"
	PredFill.Size  = UDim2.new(math.clamp(aimbotPrediction, 0, 1), 0, 1, 0)
	PredValue.Text = tostring(math.floor(aimbotPrediction * 100)) .. "%"
	RecoilStrFill.Size = UDim2.new(math.clamp(antiRecoilStrength / 100, 0, 1), 0, 1, 0)
	RecoilStrValue.Text = tostring(antiRecoilStrength) .. "%"
	TrigDelayFill.Size   = UDim2.new(trigDelay   / 500, 0, 1, 0)
	TrigDelayValue.Text  = tostring(trigDelay)  .. " ms"
	TrigDurFill.Size     = UDim2.new(trigDuration / 500, 0, 1, 0)
	TrigDurValue.Text    = tostring(trigDuration) .. " ms"
	BarTitle.TextColor3 = Color3.fromRGB(r, g, b)
	refreshDropdown()
	updateHumToggle()
	updateCXToggle()
	updateRadar()
	updateKF()
	updateDist()
	HumStrFill.Size = UDim2.new(humanizeStrength, 0, 1, 0)
	HumStrValue.Text = tostring(math.floor(humanizeStrength * 100)) .. "%"
end
local function loadSettings()
	local ok, raw = pcall(readfile, SETTINGS_FILE)
	if not ok or not raw or raw == "" then
		setStatus("No save file found", Color3.fromRGB(220, 180, 60))
		return false
	end
	local ok2, data = pcall(function() return HttpService:JSONDecode(raw) end)
	if not ok2 or type(data) ~= "table" then
		setStatus("Load failed: corrupt file", Color3.fromRGB(220, 80, 80))
		return false
	end
	espEnabled         = data.espEnabled         or false
	espVisCheckEnabled = data.espVisCheckEnabled  or false
	espTeamCheck       = data.espTeamCheck        or false
	r = data.r  or 255;  g = data.g  or 170;  b = data.b  or 200
	tr = data.tr or 50;  tg = data.tg or 150;  tb = data.tb or 255
	aimbotEnabled     = data.aimbotEnabled     or false
	aimbotFOV         = data.aimbotFOV         or 150
	aimbotSmoothing   = data.aimbotSmoothing   or 0.80
	aimbotExtraSmooth = data.aimbotExtraSmooth or 0
	aimbotPrediction  = data.aimbotPrediction  or 0
	aimbotPart        = data.aimbotPart        or "Head"
	antiRecoilEnabled = data.antiRecoilEnabled or false
	antiRecoilStrength= data.antiRecoilStrength or 20
	antiRecoilPresets = data.antiRecoilPresets or {}
	humanizeAim      = data.humanizeAim      or false
	humanizeStrength = data.humanizeStrength or 0.3
	crosshairEnabled = data.crosshairEnabled or false
	crosshairStyle   = data.crosshairStyle   or "cross"
	radarEnabled     = data.radarEnabled     or false
	radarRange       = data.radarRange       or 250
	killFeedEnabled  = type(data.killFeedEnabled) == "boolean" and data.killFeedEnabled or true
	showDist         = type(data.showDist)   == "boolean" and data.showDist or true
	triggerbotEnabled = data.triggerbotEnabled or false
	trigTeamCheck     = data.trigTeamCheck     or true
	trigDelay         = data.trigDelay         or 0
	trigDuration      = data.trigDuration      or 50
	MARK_RADIUS       = data.MARK_RADIUS       or 100
	savedKey          = data.savedKey          or nil
	if data.espKeyName then
		local kc = Enum.KeyCode[data.espKeyName]
		if kc then espKey = kc end
	end
	applySettings()
	setStatus("Loaded ?", Color3.fromRGB(80, 220, 130))
	return true
end
local function resetSettings()
	pcall(deletefile, SETTINGS_FILE)
	espEnabled = false;  espVisCheckEnabled = false;  espTeamCheck = false
	r=255; g=170; b=200;  tr=50; tg=150; tb=255
	aimbotEnabled=false; aimbotFOV=150; aimbotSmoothing=0.80
	aimbotExtraSmooth=0; aimbotPrediction=0; aimbotPart="Head"
	antiRecoilEnabled=false; antiRecoilStrength=20; antiRecoilPresets={}
	humanizeAim=false; humanizeStrength=0.3
	crosshairEnabled=false; crosshairStyle="cross"
	radarEnabled=false; radarRange=250
	killFeedEnabled=true; showDist=true
	triggerbotEnabled=false; trigTeamCheck=true
	trigDelay=0; trigDuration=50; MARK_RADIUS=100
	savedKey = nil
	espKey = Enum.KeyCode.Z
	applySettings()
	setStatus("Reset to defaults ?", Color3.fromRGB(220, 140, 60))
end
SaveBtn.MouseButton1Click:Connect(saveSettings)
LoadBtn.MouseButton1Click:Connect(loadSettings)
ResetBtn.MouseButton1Click:Connect(resetSettings)
task.spawn(function()
	task.wait(0.3)
	local loaded = loadSettings()
	if loaded then
		SetAutoLoadLabel.Text = "? Settings auto-loaded on inject"
	end
	if savedKey then
		local isValid, data = validateKey(savedKey)
		if isValid then
			hubAuthorized = true
			showGUI() 
			return
		end
	end
	hubAuthorized = false
	showKeyUI("Please enter your 48-hour key.", true)
end)
