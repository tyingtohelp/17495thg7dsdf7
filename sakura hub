local function removeESP()
	for _, obj in pairs(Workspace:GetChildren()) do
		if obj:IsA("Model") and obj.Name == "Male" then
			local highlight = obj:FindFirstChild("ESPHighlight")
			if highlight then highlight:Destroy() end
			local espDot = obj:FindFirstChild("ESPDot")
			if espDot then espDot:Destroy() end
			for _, part in pairs(obj:GetDescendants()) do
				if part:IsA("BillboardGui") and part.Name == "ESPDistLabel" then
					part:Destroy()
				end
			end
		end
	end
	pcall(function()
		local wm = LocalPlayer:FindFirstChildOfClass("WorldModel")
		if wm then
			for _, obj in pairs(wm:GetChildren()) do
				local hl = obj:FindFirstChild("ESPHighlight")
				if hl then hl:Destroy() end
				local ed = obj:FindFirstChild("ESPDot")
				if ed then ed:Destroy() end
			end
		end
	end)
end
