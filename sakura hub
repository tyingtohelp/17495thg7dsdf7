local function aimToMark()
	local mousePos = UserInputService:GetMouseLocation()
	local ray = Workspace.CurrentCamera:ViewportPointToRay(mousePos.X, mousePos.Y)
	local rParams = RaycastParams.new()
	rParams.FilterType = Enum.RaycastFilterType.Exclude
	rParams.FilterDescendantsInstances = {LocalPlayer.Character, Workspace.CurrentCamera}
	local res = Workspace:Raycast(ray.Origin, ray.Direction * 1000, rParams)
	if res and res.Instance then
		local hitModel = res.Instance:FindFirstAncestor("Male")
		if hitModel and hitModel:IsA("Model") then
			if permanentTeammateSet[hitModel] then
				permanentTeammateSet[hitModel] = nil
				MarkTeamCount.Text = "Unmarked player aim target"
			else
				permanentTeammateSet[hitModel] = true
				MarkTeamCount.Text = "Marked player from aim"
			end
			teamCheckCache = {}
			teamCheckCacheTime = {}
			task.delay(1.5, function() MarkTeamCount.Text = "No teammates marked" end)
		end
	end
end
