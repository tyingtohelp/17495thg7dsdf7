local function populateDebug()
	for _, child in pairs(DebugScroll:GetChildren()) do
		if child:IsA("TextLabel") then child:Destroy() end
	end
	local ySize = 0
	for _, obj in pairs(Workspace:GetChildren()) do
		if obj:IsA("Model") and obj.Name == "Male" then
			local hum = obj:FindFirstChildOfClass("Humanoid")
			local root = obj:FindFirstChild("Root") or obj:FindFirstChild("HumanoidRootPart") or obj.PrimaryPart
			local title = "Model: Male | DisplayName: " .. (hum and hum.DisplayName or "NIL")
			local details = "  - RootPart: " .. (root and "YES" or "NO") .. " | IsRagdoll: " .. (obj:FindFirstChildOfClass("BallSocketConstraint", true) and "YES" or "NO")
			local foundTag = "None"
			local foundValue = "None"
			for _, desc in ipairs(obj:GetDescendants()) do
				if desc:IsA("TextLabel") or desc:IsA("TextButton") then
					if desc.Text and #desc.Text > 2 and desc.Text ~= "Label" and desc.Text ~= "TextLabel" then
						foundTag = desc.Text
					end
				elseif desc:IsA("StringValue") then
					if desc.Value and #desc.Value > 2 then
						foundValue = desc.Name .. "=\"" .. desc.Value .. "\""
					end
				elseif desc:IsA("ObjectValue") then
					if desc.Value and desc.Value:IsA("Player") then
						foundValue = desc.Name .. "=@" .. desc.Value.Name
					end
				end
			end
			details = details .. "\n  - Found UI Tag: " .. foundTag .. "\n  - Found Val: " .. foundValue
			local Row = Instance.new("TextLabel")
			Row.Size = UDim2.new(1, -16, 0, 70)
			Row.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
			Row.Text = title .. "\n" .. details
			Row.TextColor3 = Color3.new(1, 1, 1)
			Row.Font = Enum.Font.Gotham
			Row.TextSize = 12
			Row.TextXAlignment = Enum.TextXAlignment.Left
			Row.ZIndex = 302
			Row.Parent = DebugScroll
			local RPad = Instance.new("UIPadding", Row)
			RPad.PaddingLeft = UDim.new(0, 10)
			Instance.new("UICorner", Row).CornerRadius = UDim.new(0, 4)
			ySize = ySize + 74
		end
	end
	DebugScroll.CanvasSize = UDim2.new(0, 0, 0, ySize)
end
