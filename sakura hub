local function dumpGunModules()
	local str = "--- WEAPON CONFIG FINDER ---\n"
	local foundGuns = {}
	local searchedCount = 0
	local function checkModule(desc)
		if not desc:IsA("ModuleScript") then return end
		searchedCount = searchedCount + 1
		local s, d = pcall(require, desc)
		if s and type(d) == "table" then
			local isGun = false
			for k, v in pairs(d) do
				local kStr = tostring(k):lower()
				if kStr:find("recoil") or kStr:find("kick") or kStr:find("spread") then
					isGun = true; break
				end
				if type(v) == "table" then
					for k2, _ in pairs(v) do
						local k2Str = tostring(k2):lower()
						if k2Str:find("recoil") or k2Str:find("kick") or k2Str:find("spread") then
							isGun = true; break
						end
					end
				end
				if isGun then break end
			end
			if isGun then
				table.insert(foundGuns, {name = desc.Name, config = d})
			end
		end
	end
	local rs = game:GetService("ReplicatedStorage")
	local paths = {
		{ "Shared", "Configs", "Weapon", "Weapons" },
		{ "Shared", "Configs", "Weapon" },
		{ "Repository", "GunModules" },
		{ "GunModules" },
		{ "Weapons" },
		{ "WeaponData" }
	}
	local targetFolder = nil
	for _, pathArray in ipairs(paths) do
		local current = rs
		local valid = true
		for _, node in ipairs(pathArray) do
			current = current:FindFirstChild(node)
			if not current then valid = false; break end
		end
		if valid and current then
			targetFolder = current
			break
		end
	end
	if targetFolder then
		for _, desc in ipairs(targetFolder:GetDescendants()) do
			checkModule(desc)
			if #foundGuns >= 3 then break end
		end
	else
		for _, obj in ipairs(rs:GetDescendants()) do
			if obj:IsA("Folder") and (obj.Name:lower():find("weapon") or obj.Name:lower():find("gun") or obj.Name:lower():find("config")) then
				for _, desc in ipairs(obj:GetChildren()) do
					checkModule(desc)
					if #foundGuns >= 3 then break end
				end
			elseif obj:IsA("ModuleScript") and (obj.Name:lower():find("weapon") or obj.Name:lower():find("gun")) then
				checkModule(obj)
			end
			if #foundGuns >= 3 then break end
		end
	end
	if #foundGuns > 0 then
		str = str .. "Found " .. #foundGuns .. " Weapon Data Files (Searched ~" .. searchedCount .. " modules):\n\n"
		local function dumpTable(t, indent, depth)
			if depth > 4 then return end
			for k, v in pairs(t) do
				str = str .. string.rep("  ", indent) .. tostring(k) .. " (" .. type(v) .. ")"
				if type(v) == "number" or type(v) == "string" or type(v) == "boolean" then
					str = str .. " = " .. tostring(v) .. "\n"
				elseif type(v) == "table" then
					str = str .. ":\n"
					dumpTable(v, indent + 1, depth + 1)
				else
					str = str .. "\n"
				end
			end
		end
		for _, wep in ipairs(foundGuns) do
			str = str .. "=== " .. wep.name .. " ===\n"
			dumpTable(wep.config, 1, 1)
			str = str .. "\n"
		end
	else
		str = str .. "Searched " .. searchedCount .. " ModuleScripts.\nNo ModuleScript found containing Recoil/Kick/Spread keys.\n"
	end
	if setclipboard then
		setclipboard(str)
		DebugDump.Text = "Copied Data!"
		task.delay(1.5, function() DebugDump.Text = "Dump Guns" end)
	else
		DebugDump.Text = "No Clipbrd"
		task.delay(1.5, function() DebugDump.Text = "Dump Guns" end)
		print(str)
	end
end
